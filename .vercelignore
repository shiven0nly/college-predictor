# Vercel Ignore File
# This file tells Vercel which files to ignore during deployment

# Don't ignore generated Prisma client - it's generated during build
# !app/generated/

# Ignore development files
.env.local
.env.development
.env.test

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore test files
coverage/
.nyc_output/

